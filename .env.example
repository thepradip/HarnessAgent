# =============================================================================
# HarnessAgent — Environment Variables Example
# Copy to .env and fill in real values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default model to use when no explicit model is provided
DEFAULT_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# OpenAI-compatible vendors (set a key to enable; all speak the OpenAI API)
# Optional overrides per vendor: <VENDOR>_BASE_URL, <VENDOR>_MODELS (comma-sep)
# -----------------------------------------------------------------------------
# DEEPSEEK_API_KEY=sk-xxxx                # deepseek-chat (cheap), deepseek-reasoner (premium)
# TOGETHER_API_KEY=xxxx                   # Llama / Qwen / Mixtral open models
# FIREWORKS_API_KEY=fw-xxxx
# GROQ_API_KEY=gsk-xxxx                   # ultra-fast inference (cheap tier)
# OPENROUTER_API_KEY=sk-or-xxxx           # meta-router across providers
# MISTRAL_API_KEY=xxxx
# XAI_API_KEY=xai-xxxx                    # Grok

# -----------------------------------------------------------------------------
# AWS Bedrock (Claude via AnthropicBedrock + general models via Converse)
# Requires: pip install agent-haas[bedrock,anthropic]; AWS creds via std chain.
# Model lists are "id:tier" comma-separated.
# -----------------------------------------------------------------------------
# BEDROCK_ENABLED=true
# BEDROCK_REGION=us-east-1
# BEDROCK_CLAUDE_MODELS=anthropic.claude-opus-4-7:premium,anthropic.claude-haiku-4-5:cheap
# BEDROCK_CONVERSE_MODELS=meta.llama3-3-70b-instruct-v1:0:standard

# -----------------------------------------------------------------------------
# Code-execution sandbox provider
#   docker (default) — local Docker (SANDBOX_RUNTIME=runc/runsc/kata)
#   e2b              — E2B cloud micro-VM; pip install agent-haas[e2b]
#   modal            — Modal serverless container; pip install agent-haas[modal]
# -----------------------------------------------------------------------------
# SANDBOX_PROVIDER=e2b
# E2B_API_KEY=e2b_xxxx
# E2B_TEMPLATE=                          # optional template id; empty = SDK default
# --- or Modal ---
# SANDBOX_PROVIDER=modal
# MODAL_TOKEN_ID=ak-xxxx
# MODAL_TOKEN_SECRET=as-xxxx
# MODAL_APP_NAME=agent-haas-sandbox

# -----------------------------------------------------------------------------
# Cost-aware routing
# Auto-pick a tier (cheap/standard/premium) by query complexity. On by default.
# ROUTING_TENANT_TIERS maps each tenant to its own model per tier (JSON).
# -----------------------------------------------------------------------------
# ROUTING_COMPLEXITY_ENABLED=true
# ROUTING_TENANT_TIERS={"acme":{"cheap":["deepseek:deepseek-chat"],"standard":["openai:gpt-4o-mini"],"premium":["anthropic:claude-sonnet-4-6"]}}

# -----------------------------------------------------------------------------
# Vector Store
# backend: chroma | qdrant | weaviate
# -----------------------------------------------------------------------------
VECTOR_BACKEND=chroma
CHROMA_PATH=/data/chroma
QDRANT_URL=http://localhost:6333
WEAVIATE_URL=http://localhost:8080

# Embedding model (sentence-transformers compatible name)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# Graph Store
# backend: networkx | neo4j
# -----------------------------------------------------------------------------
GRAPH_BACKEND=networkx
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=harnesspassword

# -----------------------------------------------------------------------------
# Redis (session store, rate limiter, LLM cache, task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# MLflow Experiment Tracking
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=harness-agent

# -----------------------------------------------------------------------------
# OpenTelemetry (OTLP gRPC endpoint)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=harness-agent

# -----------------------------------------------------------------------------
# Agent Workspace
# Base directory for per-run sandboxed workspaces
# -----------------------------------------------------------------------------
WORKSPACE_BASE_PATH=/workspaces

# -----------------------------------------------------------------------------
# Hermes Self-Healing Agent
# -----------------------------------------------------------------------------
HERMES_AUTO_APPLY=false
HERMES_INTERVAL_SECONDS=3600.0
HERMES_MIN_ERRORS_TO_TRIGGER=5
HERMES_PATCH_SCORE_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Auth & Security
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production-use-a-256bit-random-string

# -----------------------------------------------------------------------------
# Budgets & Rate Limits
# -----------------------------------------------------------------------------
COST_BUDGET_USD_PER_TENANT=100.0
RATE_LIMIT_RPM=60

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=dev
LOG_LEVEL=INFO
WORKER_CONCURRENCY=4

# -----------------------------------------------------------------------------
# External APIs (used by MCP servers)
# -----------------------------------------------------------------------------
BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codex
